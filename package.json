{
  "name": "fujian-food-ai",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev:electron": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json && node scripts/postbuild-server.cjs",
    "start": "node server-dist/index.js",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "electron:build": "npm run build:server && npm run build && electron-builder",
    "electron:dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://localhost:5173 && electron .\""
  },
  "dependencies": {
    "@tdesign-react/aigc": "^0.1.0-alpha.1",
    "@tdesign-react/chat": "^1.0.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "tdesign-icons-react": "^0.5.0",
    "tdesign-react": "^1.12.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "less": "^4.3.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.fujian.food-ai",
    "productName": "福建非遗美食助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server-dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "asarUnpack": [],
    "npmRebuild": false,
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "福建非遗美食助手"
    }
  }
}
